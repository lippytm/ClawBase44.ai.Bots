# Environment — copy to .env and fill in your secrets
# -------------------------------------------------------

# ── OpenAI / ChatGPT ────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o

# ── Grok / xAI ──────────────────────────────────────────
GROK_API_KEY=xai-...
GROK_BASE_URL=https://api.x.ai/v1
GROK_MODEL=grok-beta

# ── ManyChat ────────────────────────────────────────────
MANYCHAT_API_KEY=...
MANYCHAT_BOT_ID=...

# ── Web3 ────────────────────────────────────────────────
WEB3_RPC_URL=https://mainnet.infura.io/v3/YOUR_PROJECT_ID
WEB3_CHAIN_ID=1
WEB3_WALLET_ADDRESS=0x...
WEB3_PRIVATE_KEY=0x...          # Never commit a real key!

# ── Affiliate ───────────────────────────────────────────
AFFILIATE_DEFAULT_TAG=clawbase44-20

# ── Scheduler ───────────────────────────────────────────
SCHEDULER_TIMEZONE=UTC
